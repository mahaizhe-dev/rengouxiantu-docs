{
  "$schema": "../schemas/settings.schema.json",
  "sources": {
    "engine": {
      "tag": "stable"
    },
    "engine-res": {
      "tag": "stable"
    },
    "official-res": {
      "tag": "stable"
    }
  },
  "build": {
    "generate_fs_path": true,
    "output_dir": "../dist",
    "asset_dirs": [
      "../assets",
      "../scripts"
    ],
    "asset_ignores": []
  },
  "@runtime": {
    "multiplayer": {
      "enabled": true,
      "max_players": 8,
      "background_match": true,
      "match_info": {
        "desc_name": "free_match_with_ai",
        "immediately_start": true,
        "match_timeout": 3,
        "player_number": 1
      },
      "persistent_world": {
        "enabled": false
      }
    }
  }
}