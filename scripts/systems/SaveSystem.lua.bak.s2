--- 反序列化商店数据（兼容旧存档：tigerPillCount 迁移到 AlchemyUI）
---@param data table
function SaveSystem.DeserializeShop(data)
    if not data then return end
    local AlchemyUI = require("ui.AlchemyUI")
    AlchemyUI.SetTigerPillCount(data.tigerPillCount or 0)
    AlchemyUI.SetSnakePillCount(data.snakePillCount or 0)
    AlchemyUI.SetDiamondPillCount(data.diamondPillCount or 0)
    AlchemyUI.SetTemperingPillEaten(data.temperingPillEaten or 0)
    print("[SaveSystem] Shop data restored: tigerPill=" .. (data.tigerPillCount or 0) .. " snakePill=" .. (data.snakePillCount or 0) .. " diamondPill=" .. (data.diamondPillCount or 0) .. " temperingPill=" .. (data.temperingPillEaten or 0))
end

-- ============================================================================
-- 槽位索引管理
-- ============================================================================

-- ======== v11 统一 key 命名（S1 三键合并） ========

--- 通用 key 生成函数（v11+）
--- 所有存档 key 统一为 "{layer}_{slot}" 格式
---@param layer string "save"|"login"|"prev"|"deleted"|"premigrate"
---@param slot number 槽位号
---@return string
function SaveSystem.GetKey(layer, slot)
    return layer .. "_" .. slot
end

--- 获取指定 slot 的所有旧格式 key（v10 三键架构）
--- 用于迁移期 fallback 读取和旧 key 清理
---@param slot number
---@return table
function SaveSystem.GetLegacyKeys(slot)
    return {
        save     = "save_data_" .. slot,
        bag1     = "save_bag1_" .. slot,
        bag2     = "save_bag2_" .. slot,
        prev     = "save_prev_" .. slot,
        prevBag1 = "prev_bag1_" .. slot,
        prevBag2 = "prev_bag2_" .. slot,
        login    = "save_login_backup_" .. slot,
        loginBag1 = "login_bag1_" .. slot,
        loginBag2 = "login_bag2_" .. slot,
        backup   = "save_backup_" .. slot,
        bakBag1  = "bak_bag1_" .. slot,
        bakBag2  = "bak_bag2_" .. slot,
    }
end

-- ======== 以下为 v10 旧 key 函数（S1 迁移期保留，逐步替换后删除） ========

---@deprecated 使用 GetKey("save", slot) 或 GetLegacyKeys(slot).save
function SaveSystem.GetSaveKey(slot)
    return "save_data_" .. slot
end

---@deprecated 使用 GetKey("deleted", slot) 或 GetLegacyKeys(slot).backup
function SaveSystem.GetBackupKey(slot)
    return "save_backup_" .. slot
end

---@deprecated 使用 GetKey("prev", slot) 或 GetLegacyKeys(slot).prev
function SaveSystem.GetPrevKey(slot)
    return "save_prev_" .. slot
end

---@deprecated 使用 GetLegacyKeys(slot).bag1 — v11 后无 bag 分离
function SaveSystem.GetBag1Key(slot)
    return "save_bag1_" .. slot
end

---@deprecated
function SaveSystem.GetBag2Key(slot)
    return "save_bag2_" .. slot
end

---@deprecated
function SaveSystem.GetPrevBag1Key(slot)
    return "prev_bag1_" .. slot
end

---@deprecated
function SaveSystem.GetPrevBag2Key(slot)
    return "prev_bag2_" .. slot
end

---@deprecated
function SaveSystem.GetLoginBag1Key(slot)
    return "login_bag1_" .. slot
end

---@deprecated
function SaveSystem.GetLoginBag2Key(slot)
    return "login_bag2_" .. slot
end

---@deprecated
function SaveSystem.GetBakBag1Key(slot)
    return "bak_bag1_" .. slot
end

---@deprecated
function SaveSystem.GetBakBag2Key(slot)
    return "bak_bag2_" .. slot
end

---@param callback function|nil (slotsIndex: table|nil, error: string|nil)
function SaveSystem.FetchSlots(callback)
    -- 网络模式：通过 C2S_FetchSlots 远程事件路由到服务端
    if CloudStorage.IsNetworkMode() then
        return SaveSystemNet.FetchSlots(callback)
    end

    print("[SaveSystem] Fetching slots index...")

    CloudStorage.BatchGet()
        :Key("slots_index")
        :Key("save_data")    -- 旧版 key，用于兼容迁移
        :Key("save_data_1")  -- 验证槽位数据完整性
        :Key("save_data_2")
        :Key("save_data_3")
        :Key("save_data_4")
        :Key("account_bulletin")  -- 账号级公告数据（补偿领取等）
        :Fetch({
            ok = function(values, iscores)
                -- 加载账号级公告数据（补偿领取记录）
                if values.account_bulletin then
                    local BulletinUI = require("ui.BulletinUI")
                    BulletinUI.DeserializeAccount(values.account_bulletin)
                end
                if values.slots_index then
                    local index = values.slots_index
                    -- P0-D: 正向验证 — 索引有条目但数据丢失
                    index.slots = index.slots or {}
                    for slot = 1, SaveSystem.MAX_SLOTS do
                        if index.slots[slot] then
                            local saveKey = SaveSystem.GetSaveKey(slot)
                            local hasData = values[saveKey] and type(values[saveKey]) == "table"
                            if not hasData then
                                -- 云端数据丢失：先检查本地缓存（Save 后云端尚未同步的数据）
                                local cached = SaveSystem._lastSavedData and SaveSystem._lastSavedData[slot]
                                if cached and type(cached) == "table" then
                                    print("[SaveSystem] Slot " .. slot
                                        .. " cloud data missing but LOCAL CACHE available (Lv."
                                        .. (cached.player and cached.player.level or "?")
                                        .. "), skipping dataLost")
                                else
                                    index.slots[slot].dataLost = true
                                    print("[SaveSystem] WARNING: Slot " .. slot
                                        .. " index exists but save data is MISSING!")
                                end
                            end
                        end
                    end

                    -- P0-D: 反向验证 — 数据存在但索引无条目（孤儿存档自愈）
                    local needRepair = false
                    for slot = 1, SaveSystem.MAX_SLOTS do
                        if not index.slots[slot] then
                            local saveKey = SaveSystem.GetSaveKey(slot)
                            local saveData = values[saveKey]
                            if saveData and type(saveData) == "table" and saveData.player then
                                -- 孤儿存档：从存档数据重建索引条目
                                local p = saveData.player
                                local realm = p.realm or "mortal"
                                local realmCfg = GameConfig.REALMS[realm]
                                local realmName = realmCfg and realmCfg.name or "凡人"
                                index.slots[slot] = {
                                    name = p.charName or SaveSystem.DEFAULT_CHARACTER_NAME,
                                    level = p.level or 1,
                                    realm = realm,
                                    realmName = realmName,
                                    chapter = p.chapter or 1,
                                    lastSave = saveData.timestamp or os.time(),
                                    saveVersion = saveData.version or 1,
                                    recovered = true,  -- 标记为自愈恢复
                                }
                                needRepair = true
                                print("[SaveSystem] RECOVERED orphan slot " .. slot
                                    .. ": Lv." .. (p.level or 1) .. " " .. realmName)
                            end
                        end
                    end

                    -- 如果有孤儿槽位被修复，异步写回修复后的索引
                    if needRepair then
                        CloudStorage.BatchSet()
                            :Set("slots_index", index)
                            :Save("自愈修复slots_index", {
                                ok = function()
                                    print("[SaveSystem] Orphan slots repaired in cloud")
                                end,
                                error = function(code, reason)
                                    print("[SaveSystem] Orphan repair write failed: " .. tostring(reason))
                                end,
                            })
                    end

                    -- 汇总 dataLost 状态
                    local lostSlots = {}
                    for slot = 1, SaveSystem.MAX_SLOTS do
                        if index.slots[slot] and index.slots[slot].dataLost then
                            table.insert(lostSlots, slot)
                        end
                    end

                    if #lostSlots > 0 then
                        print("[SaveSystem] dataLost remains for slot(s): " .. table.concat(lostSlots, ","))
                    else
                        print("[SaveSystem] Slots index found (all data intact)")
                    end
                    if callback then callback(index, nil) end
                    return
                end

                -- 全新玩家
                print("[SaveSystem] No save data found, new player")
                if callback then callback({ version = 1, slots = {} }, nil) end
            end,
            error = function(code, reason)
                print("[SaveSystem] Fetch slots failed: " .. tostring(reason))
                if callback then callback(nil, reason) end
            end,
        })
end

--- 更新槽位索引（保存时同步更新摘要）
---@param slot number
---@param charName string
---@param playerData table
---@return table 新的 slot 摘要
function SaveSystem.BuildSlotSummary(slot, charName, playerData)
    local realm = playerData.realm or "mortal"
    local realmCfg = GameConfig.REALMS[realm]
    local realmName = realmCfg and realmCfg.name or "凡人"

    return {
        name = charName or SaveSystem.DEFAULT_CHARACTER_NAME,
        level = playerData.level or 1,
        realm = realm,
        realmName = realmName,
        chapter = playerData.chapter or 1,
        lastSave = os.time(),
        saveVersion = SaveSystem.CURRENT_SAVE_VERSION,
    }
end

-- ============================================================================
-- 保存（原子写入，零预检）
-- ============================================================================

--- 保存存档：本地安全检查 + 单次原子 BatchSet
--- 改进：移除了保存前的 BatchGet 预检（减少 1 次网络请求），
--- 将 save_data_X / slots_index / rank / checkpoint 合并到同一个 BatchSet（原子一致性）
---@param callback function|nil (success: boolean, message: string|nil)
function SaveSystem.Save(callback)
    -- 超时自动解锁：如果 saving 卡死超过 30 秒，强制解锁并计入失败
    if SaveSystem.saving then
        local elapsed = os.time() - SaveSystem._savingStartTime
        if elapsed > 30 then
            print("[SaveSystem] saving flag stuck for " .. elapsed .. "s, force unlocking")
            SaveSystem.saving = false
            SaveSystem._saveTimeoutActive = false
            -- 方案4: 计入连续失败，触发退避重试
            SaveSystem._consecutiveFailures = SaveSystem._consecutiveFailures + 1
            local retryDelay = math.min(10 * SaveSystem._consecutiveFailures, 60)
            SaveSystem._retryTimer = retryDelay
            print("[SaveSystem] 30s stuck unlock: "
                .. SaveSystem._consecutiveFailures .. " consecutive failures, retry in " .. retryDelay .. "s")
            if SaveSystem._consecutiveFailures >= 2 then
                EventBus.Emit("save_warning", { failures = SaveSystem._consecutiveFailures })
            end
            return
        else
            print("[SaveSystem] Save already in progress, skipping")
            return
        end
    end
    if not SaveSystem.loaded then
        print("[SaveSystem] Not loaded, save skipped")
        return
    end
    if not SaveSystem.activeSlot then
        print("[SaveSystem] No active slot, save skipped")
        return
    end
    -- W2: 断线期间暂停存档（避免无意义的失败重试）
    if SaveSystem._disconnected then
        print("[SaveSystem] Save skipped: disconnected")
        if callback then callback(false, "Disconnected") end
        return
    end

    local currentLevel = GameState.player and GameState.player.level or 1
    local slot = SaveSystem.activeSlot

    -- 本地安全阀：防止内存中等级被意外清零后覆盖云端有效存档
    -- 无需网络请求，使用上次成功加载时记录的云端等级作为参照
    if SaveSystem._lastKnownCloudLevel > 10 and currentLevel < SaveSystem._lastKnownCloudLevel * 0.5 then
        print("[SaveSystem] SAVE BLOCKED (local check): current Lv." .. currentLevel
            .. " << known cloud Lv." .. SaveSystem._lastKnownCloudLevel)
        EventBus.Emit("save_blocked", {
            cloudLevel = SaveSystem._lastKnownCloudLevel,
            currentLevel = currentLevel,
        })
        if callback then callback(false, "存档保护：数据异常") end
        return
    end

    -- 方案6: serverConn 预检 —— 网络模式下若无连接，直接快速失败
    if CloudStorage.IsNetworkMode() and not network:GetServerConnection() then
        SaveSystem._consecutiveFailures = SaveSystem._consecutiveFailures + 1
        local retryDelay = math.min(10 * SaveSystem._consecutiveFailures, 60)
        SaveSystem._retryTimer = retryDelay
        print("[SaveSystem] Save SKIPPED: no serverConn, "
            .. SaveSystem._consecutiveFailures .. " consecutive failures, retry in " .. retryDelay .. "s")
        if SaveSystem._consecutiveFailures >= 2 then
            EventBus.Emit("save_warning", { failures = SaveSystem._consecutiveFailures })
        end
        if callback then callback(false, "No server connection") end
        return
    end

    SaveSystem.saving = true
    SaveSystem._savingStartTime = os.time()
    -- 方案1补充: 网络模式下激活 15s 响应超时检测
    SaveSystem._saveTimeoutElapsed = 0
    SaveSystem._saveTimeoutActive = CloudStorage.IsNetworkMode()

    local epoch = SaveSystem._saveEpoch  -- 捕获当前纪元
    SaveSystem.DoSave(slot, callback, epoch)
end

--- 执行实际保存操作（单次原子 BatchSet）
--- 将 save_data_X / slots_index / rank / checkpoint 全部合并到一个 BatchSet 请求
--- 一次网络请求，全部成功或全部失败，杜绝 slots_index 与 save_data_X 不一致
---@param slot number 槽位号
---@param callback function|nil
---@param epoch number 捕获的纪元
function SaveSystem.DoSave(slot, callback, epoch)
    -- 安全闸门：未正常加载存档时禁止写入（防旧代码覆写新存档）
    if not SaveSystem.loaded then
        print("[SaveSystem] DoSave BLOCKED: data not loaded (forward version check or load failure)")
        if callback then callback(false, "存档未加载，禁止写入") end
        return
    end

    -- 纪元检查
    if epoch and epoch ~= SaveSystem._saveEpoch then
        print("[SaveSystem] DoSave: stale epoch, aborting")
        return
    end

    local playerData = SaveSystem.SerializePlayer()
    -- v11 单键：equipment + backpack 全部嵌入 coreData
    local equippedData = SaveSystem.SerializeEquipped()
    local backpackData = SaveSystem.SerializeBackpack()
    local skillData = SaveSystem.SerializeSkills()
    local collectionData = SaveSystem.SerializeCollection()
    local petData = SaveSystem.SerializePet()

    local QuestSystem = require("systems.QuestSystem")
    local questData = QuestSystem.Serialize()
    local shopData = SaveSystem.SerializeShop()

    local titlesData = SaveSystem.SerializeTitles()

    local ChallengeSystem = require("systems.ChallengeSystem")
    local challengeData = ChallengeSystem.Serialize()

    local SealDemonSystem = require("systems.SealDemonSystem")
    local sealDemonData = SealDemonSystem.Serialize()

    local BulletinUI = require("ui.BulletinUI")
    local bulletinData = BulletinUI.Serialize()
    local accountBulletinData = BulletinUI.SerializeAccount()

    -- 序列化BOSS击杀冷却（转换为相对剩余时间，与gameTime解耦）
    local bossKillData = {}
    for typeId, record in pairs(GameState.bossKillTimes) do
        local killTime = type(record) == "table" and record.killTime or record
        local respawnTime = type(record) == "table" and record.respawnTime or 180
        local remaining = killTime + respawnTime - GameState.gameTime
        if remaining > 0 then
            bossKillData[typeId] = { remaining = remaining, respawnTime = respawnTime }
        end
    end

    -- v11 单键架构：所有数据合并到一个 save_{slot} key（~16-19KB，上限 1MB）
    local coreData = {
        version = SaveSystem.CURRENT_SAVE_VERSION,
        code_version = GameConfig.CODE_VERSION,
        timestamp = os.time(),
        player = playerData,
        equipment = equippedData,  -- 已装备物品（全字段，最核心）
        backpack = backpackData,   -- v11: 背包全量嵌入（不再拆分 bag1/bag2）
        skills = skillData,
        collection = collectionData,
        pet = petData,
        quests = questData,
        shop = shopData,
        titles = titlesData,
        bossKillTimes = bossKillData,
        bossKills = GameState.bossKills or 0,
        _bossKillsMigrated = true,
        bulletin = bulletinData,
        challenges = challengeData,
        sealDemon = sealDemonData,
        trialTower = (function()
            local TrialTowerSystem = require("systems.TrialTowerSystem")
            return TrialTowerSystem.Serialize()
        end)(),
        artifact = (function()
            local ArtifactSystem = require("systems.ArtifactSystem")
            return ArtifactSystem.Serialize()
        end)(),
        fortuneFruits = (function()
            local FortuneFruitSystem = require("systems.FortuneFruitSystem")
            return FortuneFruitSystem.Serialize()
        end)(),
        seaPillar = (function()
            local SeaPillarSystem = require("systems.SeaPillarSystem")
            return SeaPillarSystem.Serialize()
        end)(),
    }

    -- v11 新 key + 旧 key（迁移用）
    local saveKey = SaveSystem.GetKey("save", slot)
    local legacy = SaveSystem.GetLegacyKeys(slot)

    -- 重组完整 saveData（供本地缓存和大小监控使用）
    local saveData = {}
    for k, v in pairs(coreData) do saveData[k] = v end
    saveData.inventory = { equipment = equippedData, backpack = backpackData }

    -- 数据大小监控（真实 JSON 序列化大小）
    local function measureSize(label, data)
        if cjson and cjson.encode then
            local ok, json = pcall(cjson.encode, data)
            if ok and json then
                local bytes = #json
                local kb = string.format("%.1f", bytes / 1024)
                print("[SaveSystem] " .. label .. ": " .. kb .. "KB (" .. bytes .. " bytes)")
                if bytes > 9 * 1024 then
                    print("[SaveSystem] WARNING: " .. label .. " approaching 10KB limit!")
                end
                return bytes
            end
        end
        return 0
    end
    local totalBytes = measureSize("saveData (" .. saveKey .. ")", coreData)

    -- S3 审计：字段级大小分解（每 10 次存档输出一次详细报告）
    SaveSystem._auditCounter = (SaveSystem._auditCounter or 0) + 1
    if SaveSystem._auditCounter % 10 == 1 and cjson and cjson.encode then
        local parts = {}
        for field, value in pairs(coreData) do
            if field ~= "version" and field ~= "timestamp" then
                local fOk, fJson = pcall(cjson.encode, value)
                if fOk and fJson then
                    parts[#parts + 1] = { field = field, bytes = #fJson }
                end
            end
        end
        table.sort(parts, function(a, b) return a.bytes > b.bytes end)
        local report = {}
        for _, p in ipairs(parts) do
            report[#report + 1] = string.format("  %s: %.1fKB", p.field, p.bytes / 1024)
        end
        print("[SaveSystem] === AUDIT: saveData field breakdown ===")
        print(table.concat(report, "\n"))
        print(string.format("[SaveSystem] === TOTAL: %.1fKB (single key) ===",
            totalBytes / 1024))
    end

    -- 🔴 图鉴退化检测：如果当前图鉴数量比上次已知数量大幅减少，用缓存替代
    local collectionCount = #collectionData
    local prevCount = SaveSystem._lastKnownCollectionCount or 0
    if prevCount > 2 and collectionCount < prevCount * 0.5 then
        print("[SaveSystem] 🚨 COLLECTION DEGRADATION DETECTED! prev=" .. prevCount
            .. " → current=" .. collectionCount .. " (>50% loss)")
        -- 用缓存的完整图鉴数据替代退化数据
        if SaveSystem._cachedCollectionData and #SaveSystem._cachedCollectionData >= prevCount then
            saveData.collection = SaveSystem._cachedCollectionData
            print("[SaveSystem] Collection replaced with cached data (" .. #SaveSystem._cachedCollectionData .. " entries)")
        else
            print("[SaveSystem] WARNING: no cached collection data, saving degraded data as-is")
        end
    else
        -- 正常情况：更新缓存（值拷贝，防止外部修改污染缓存）
        SaveSystem._lastKnownCollectionCount = collectionCount
        if collectionCount > 0 then
            local cached = {}
            for i, v in ipairs(collectionData) do cached[i] = v end
            SaveSystem._cachedCollectionData = cached
        end
    end

    -- 构建 slots_index 更新（使用缓存的角色名，无需网络读取）
    local charName = SaveSystem._cachedCharName or SaveSystem.DEFAULT_CHARACTER_NAME
    local updatedIndex = SaveSystem._cachedSlotsIndex  -- 不再 fallback 空表！

    -- 🔴 在发送 BatchSet 之前就缓存 saveData（不依赖异步回调）
    -- 原因：Save 的 ok 回调可能在 Init() 增加 epoch 之后才返回，
    -- 导致纪元检查 return，缓存永远不会被设置。
    -- 而 FetchSlots/Load 需要此缓存来应对云端同步延迟。
    SaveSystem._lastSavedData = SaveSystem._lastSavedData or {}
    SaveSystem._lastSavedData[slot] = saveData

    -- 🔴 v11 迁移前快照：首次 Save 时将旧格式原始数据写入 premigrate key
    -- _rawOldData[slot] 由 Load 检测到旧三键格式时缓存（见 Step 4）
    local needPreMigrate = false
    SaveSystem._preMigrateWritten = SaveSystem._preMigrateWritten or {}
    if not SaveSystem._preMigrateWritten[slot]
        and SaveSystem._rawOldData
        and SaveSystem._rawOldData[slot] then
        needPreMigrate = true
    end

    --- 向 batch 中添加迁移清理条目（新旧 key 切换 + 可选的 premigrate 快照）
    local function addMigrationOps(batch)
        -- 删除旧三键
        batch:Delete(legacy.save)
        batch:Delete(legacy.bag1)
        batch:Delete(legacy.bag2)
        -- 首次迁移：写入 premigrate 快照（与 delete 在同一原子 batch）
        if needPreMigrate then
            local raw = SaveSystem._rawOldData[slot]
            batch:Set(SaveSystem.GetKey("premigrate", slot), raw.coreData)
            batch:Set("premigrate_bag1_" .. slot, raw.bag1)
            batch:Set("premigrate_bag2_" .. slot, raw.bag2)
            print("[SaveSystem] Pre-migrate snapshot added to batch for slot " .. slot)
        end
        return batch
    end

    --- 首次迁移完成后的清理
    local function onMigrateComplete()
        if needPreMigrate then
            SaveSystem._preMigrateWritten[slot] = true
            SaveSystem._rawOldData[slot] = nil
            print("[SaveSystem] Pre-migrate snapshot committed for slot " .. slot)
        end
    end

    -- 纵深防御：如果缓存为 nil，说明 Init 与 CharacterSelectScreen 之间存在时序问题
    -- 此时只写 save_{slot}，不触碰 slots_index 和排行（避免覆写丢失其他槽位）
    if not updatedIndex then
        print("[SaveSystem] WARNING: _cachedSlotsIndex is nil! Saving data only (no index/rank update)")

        -- v11 单键写入 + 迁移清理旧 key
        local batch = CloudStorage.BatchSet()
            :Set(saveKey, coreData)
        addMigrationOps(batch)

        -- 定期备份计数（checkpoint 拆分为独立请求，不再搭车主 batch）
        SaveSystem._saveCount = SaveSystem._saveCount + 1
        local isCheckpoint = SaveSystem._saveCount == 1
            or SaveSystem._saveCount % SaveSystem.CHECKPOINT_INTERVAL == 0

        batch:Save("存档(仅数据)", {
            ok = function()
                if epoch and epoch ~= SaveSystem._saveEpoch then return end
                SaveSystem.saving = false
                SaveSystem._saveTimeoutActive = false
                SaveSystem._consecutiveFailures = 0
                SaveSystem._retryTimer = nil
                SaveSystem._lastKnownCloudLevel = playerData.level or 1
                EventBus.Emit("save_warning_clear")
                onMigrateComplete()
                print("[SaveSystem] Slot " .. slot .. " saved (data only, no index) [v11]")
                EventBus.Emit("game_saved")
                if callback then callback(true) end

                -- checkpoint 独立写入（fire-and-forget，不影响主存档流程）
                if isCheckpoint then
                    SaveSystem.ExportToLocalFile(slot, coreData, nil)
                    local prevKey = SaveSystem.GetKey("prev", slot)
                    CloudStorage.BatchSet()
                        :Set(prevKey, coreData)
                        :Delete(legacy.prev)
                        :Delete(legacy.prevBag1)
                        :Delete(legacy.prevBag2)
                        :Save("checkpoint(仅数据)", {
                            ok = function()
                                print("[SaveSystem] Checkpoint written (data only): " .. prevKey .. " [v11]")
                            end,
                            error = function(code, reason)
                                print("[SaveSystem] Checkpoint write failed (data only): " .. tostring(reason))
                            end,
                        })
                end
            end,
            error = function(code, reason)
                if epoch and epoch ~= SaveSystem._saveEpoch then return end
                SaveSystem.saving = false
                SaveSystem._saveTimeoutActive = false
                SaveSystem._consecutiveFailures = SaveSystem._consecutiveFailures + 1
                local retryDelay = math.min(10 * SaveSystem._consecutiveFailures, 60)
                SaveSystem._retryTimer = retryDelay
                print("[SaveSystem] Save FAILED (data only): " .. tostring(reason))
                if SaveSystem._consecutiveFailures >= 2 then
                    EventBus.Emit("save_warning", { failures = SaveSystem._consecutiveFailures })
                end
                if callback then callback(false, reason) end
            end,
        })
        return
    end

    updatedIndex.slots = updatedIndex.slots or {}
    updatedIndex.slots[slot] = SaveSystem.BuildSlotSummary(slot, charName, playerData)

    -- 构建排行数据
    local realmCfg = GameConfig.REALMS[playerData.realm or "mortal"]
    local realmOrder = realmCfg and realmCfg.order or 0
    local rankScore = realmOrder * 1000 + (playerData.level or 1)
    local rankScoreKey = "rank_score_" .. slot
    local rankInfoKey = "rank_info_" .. slot

    -- v11 单键写入 + 迁移清理旧 key（原子 BatchSet）
    local batch = CloudStorage.BatchSet()
        :Set(saveKey, coreData)
        :Set("slots_index", updatedIndex)
        :SetInt("player_level", playerData.level or 1)
        :Set("account_bulletin", accountBulletinData)
    addMigrationOps(batch)

    -- 排行榜（等级 > 5 时写入）
    local bossKillsCount = GameState.bossKills or 0
    local rankTimeKey = "rank_time_" .. slot
    if (playerData.level or 1) > 5 then
        batch:SetInt(rankScoreKey, rankScore)
        batch:SetInt("boss_kills_" .. slot, bossKillsCount)
        -- 达成时间：仅在分数提升时更新（同分时先达成者排前）
        local lastScore = GameState.lastRankScore or 0
        if rankScore > lastScore then
            local achieveTime = os.time()
            batch:SetInt(rankTimeKey, achieveTime)
            GameState.lastRankScore = rankScore
            GameState.lastRankTime = achieveTime
        end
        batch:Set(rankInfoKey, {
            name = charName,
            realm = playerData.realm or "mortal",
            level = playerData.level or 1,
            bossKills = bossKillsCount,
        })
    end

    -- 定期备份计数（checkpoint 拆分为独立请求，不再搭车主 batch）
    SaveSystem._saveCount = SaveSystem._saveCount + 1
    local isCheckpoint = SaveSystem._saveCount == 1
        or SaveSystem._saveCount % SaveSystem.CHECKPOINT_INTERVAL == 0

    batch:Save("存档", {
        ok = function()
            -- 纪元检查
            if epoch and epoch ~= SaveSystem._saveEpoch then
                print("[SaveSystem] Save ok: stale epoch, discarding")
                return
            end
            SaveSystem.saving = false
            SaveSystem._saveTimeoutActive = false
            SaveSystem._consecutiveFailures = 0
            SaveSystem._retryTimer = nil
            EventBus.Emit("save_warning_clear")

            -- 更新缓存的 slots_index（供下次 Save 使用）
            SaveSystem._cachedSlotsIndex = updatedIndex

            -- 更新本地安全阀参照等级
            SaveSystem._lastKnownCloudLevel = playerData.level or 1
            onMigrateComplete()

            local checkpointMsg = isCheckpoint and " [+checkpoint]" or ""
            print("[SaveSystem] Slot " .. slot .. " saved! [v11]" .. checkpointMsg)
            EventBus.Emit("game_saved")
            if callback then callback(true) end

            -- checkpoint 独立写入（fire-and-forget，不影响主存档流程）
            if isCheckpoint then
                SaveSystem.ExportToLocalFile(slot, coreData, updatedIndex)
                local prevKey = SaveSystem.GetKey("prev", slot)
                CloudStorage.BatchSet()
                    :Set(prevKey, coreData)
                    :Delete(legacy.prev)
                    :Delete(legacy.prevBag1)
                    :Delete(legacy.prevBag2)
                    :Save("checkpoint", {
                        ok = function()
                            print("[SaveSystem] Checkpoint written: " .. prevKey .. " [v11]")
                        end,
                        error = function(code, reason)
                            print("[SaveSystem] Checkpoint write failed: " .. tostring(reason))
                        end,
                    })
            end
        end,
        error = function(code, reason)
            -- 纪元检查
            if epoch and epoch ~= SaveSystem._saveEpoch then
                print("[SaveSystem] Save error: stale epoch, ignoring")
                return
            end
            SaveSystem.saving = false
            SaveSystem._saveTimeoutActive = false
            SaveSystem._consecutiveFailures = SaveSystem._consecutiveFailures + 1

            -- 失败重试：指数退避，最长 60 秒
            local retryDelay = math.min(10 * SaveSystem._consecutiveFailures, 60)
            SaveSystem._retryTimer = retryDelay
            print("[SaveSystem] Save FAILED (" .. SaveSystem._consecutiveFailures
                .. " consecutive): " .. tostring(code) .. " - " .. tostring(reason)
                .. ", retry in " .. retryDelay .. "s")
            if SaveSystem._consecutiveFailures >= 2 then
                EventBus.Emit("save_warning", { failures = SaveSystem._consecutiveFailures })
            end

            if callback then callback(false, reason) end
        end,
    })
end

-- ============================================================================
-- 存档导出到本地文件（迁移中转用）
-- ============================================================================

--- 将存档数据导出到本地文件，供 Phase 2（enabled=true）读取并上传 serverCloud
--- v11: coreData 已包含 backpack，不再需要 bag1/bag2 参数
---@param slot number 槽位号
---@param coreData table 完整存档数据（含 equipment + backpack）
---@param slotsIndex table|nil 槽位索引（可能为 nil）
function SaveSystem.ExportToLocalFile(slot, coreData, slotsIndex)
    local exportData = {
        export_version = 2,   -- v11 格式
        export_time = os.time(),
        slot = slot,
        save_data = coreData,
        slots_index = slotsIndex,
    }
    local ok, json = pcall(cjson.encode, exportData)
    if not ok then
        print("[SaveSystem] Export encode FAILED: " .. tostring(json))
        return
    end
    local f = File("save_export_" .. slot .. ".json", FILE_WRITE)
    if f:IsOpen() then
        f:WriteString(json)
        f:Close()
        print("[SaveSystem] Export OK: slot " .. slot .. " (" .. #json .. " bytes)")

        -- 非 PC 平台（文件可持久化）：写 clientCloud 标记，供 PC 端检测
        local platform = GetPlatform()
        if platform ~= "Web" and platform ~= "Windows" then
            if clientCloud then
                clientCloud:SetInt("migration_backup_done", 1, {
                    ok = function()
                        print("[SaveSystem] migration_backup_done flag set in cloud")
                    end,
                    ng = function()
                        print("[SaveSystem] migration_backup_done flag set FAILED (non-critical)")
                    end,
                })
            end
        end
    else
        print("[SaveSystem] Export FAILED: cannot open file for slot " .. slot)
    end
end

-- ============================================================================
-- 加载（带 pcall + 完整性校验 + 丢失恢复）
-- ============================================================================

--- 处理已获取的存档数据（版本迁移 + 反序列化 + 完整性校验）
--- 由 Load 和 TryRecoverSave 共同调用
---@param slot number 槽位号
---@param saveData table 原始存档数据
---@param recoverySource string|nil 恢复来源描述（nil 表示正常加载）
---@param callback function(success: boolean, message: string)
function SaveSystem.ProcessLoadedData(slot, saveData, recoverySource, callback)
    local cloudLevel = saveData.player and saveData.player.level or 0

    local ok, err = pcall(function()
        -- 版本迁移
        local migrated, migErr = SaveSystem.MigrateSaveData(saveData)
        if not migrated then
            error(migErr)
        end
        saveData = migrated

        -- 反序列化各模块
        if saveData.player then
            SaveSystem.DeserializePlayer(saveData.player)

            -- 🔴 修正 exp 最低值：确保 exp >= EXP_TABLE[level]，否则经验条显示 0%
            local player = GameState.player
            if player then
                local minExp = GameConfig.EXP_TABLE[player.level] or 0
                if player.exp < minExp then
                    print("[SaveSystem] Fixing exp: " .. player.exp .. " < EXP_TABLE[" .. player.level .. "]=" .. minExp .. ", setting to " .. minExp)
                    player.exp = minExp
                end
            end
        end
        if saveData.inventory then
            SaveSystem.DeserializeInventory(saveData.inventory)
        end
        if saveData.skills and saveData.skills.skillBar then
            SaveSystem.DeserializeSkills(saveData.skills)
        else
            -- 恢复路径：skills 为空（元数据重建/旧版存档），根据当前等级重新解锁
            local SkillSystem = require("systems.SkillSystem")
            SkillSystem.unlockedSkills = {}
            SkillSystem.equippedSkills = {}
            SkillSystem.CheckUnlocks()
            print("[SaveSystem] Skills re-unlocked based on player level (no saved skillBar)")
        end
        if saveData.collection then
            SaveSystem.DeserializeCollection(saveData.collection)
            -- 🔴 图鉴退化检测：初始化缓存基准
            local collCount = #saveData.collection
            SaveSystem._lastKnownCollectionCount = collCount
            if collCount > 0 then
                -- 深拷贝一份用于退化检测缓存
                local cached = {}
                for i, v in ipairs(saveData.collection) do cached[i] = v end
                SaveSystem._cachedCollectionData = cached
            end
        end

        if saveData.pet then
            SaveSystem.DeserializePet(saveData.pet)
        end
        if saveData.quests then
            local QuestSystem = require("systems.QuestSystem")
            QuestSystem.Deserialize(saveData.quests)
        end
        if saveData.shop then
            SaveSystem.DeserializeShop(saveData.shop)
        end

        -- 迁移：老版本千锤百炼丹加的是生命/攻击/防御，新版改为根骨
        -- 老存档 pillConstitution 不存在(=0)，但 temperingPillEaten 有值
        do
            local AlchemyUI = require("ui.AlchemyUI")
            local eaten = AlchemyUI.GetTemperingPillEaten()
            local p = GameState.player
            if p and eaten > 0 and (p.pillConstitution or 0) == 0 then
                p.pillConstitution = eaten
                print("[SaveSystem] Migration: tempering pill constitution fix, eaten=" .. eaten .. " -> pillConstitution=" .. eaten)
            end
        end

        if saveData.titles then
            SaveSystem.DeserializeTitles(saveData.titles)
        end
        if saveData.bulletin then
            local BulletinUI = require("ui.BulletinUI")
            BulletinUI.Deserialize(saveData.bulletin)
        end
        if saveData.challenges then
            local ChallengeSystem = require("systems.ChallengeSystem")
            ChallengeSystem.Deserialize(saveData.challenges)
        end

        -- ================================================================
        -- B3 热修：丹药计数反推校验
        -- 效果已烘焙进 player 属性，计数存在 shop/challenges 中。
        -- 若计数全部为 0 但属性明显高于 base+realm → 反推恢复计数，
        -- 防止玩家重复购买导致属性翻倍。
        -- ================================================================
        do
            local p = GameState.player
            local AlchemyUI = require("ui.AlchemyUI")
            local ChallengeSystem = require("systems.ChallengeSystem")

            -- 从配置源获取丹药参数（避免硬编码）
            local shopPillCfg = AlchemyUI.GetShopPillConfigs()
            local xueshaCfg = ChallengeSystem.GetPillConfig("xuesha_dan")
            local haoqiCfg  = ChallengeSystem.GetPillConfig("haoqi_dan")
            local function findBonus(cfg, stat)
                for _, b in ipairs(cfg.bonuses) do
                    if b.stat == stat then return b.bonus end
                end
                return 0
            end

            if p then
                local tiger  = AlchemyUI.GetTigerPillCount()
                local snake  = AlchemyUI.GetSnakePillCount()
                local diamond = AlchemyUI.GetDiamondPillCount()
                local xuesha = ChallengeSystem.xueshaDanCount or 0
                local haoqi  = ChallengeSystem.haoqiDanCount or 0

                local allShopZero = (tiger == 0 and snake == 0 and diamond == 0)
                local allChallengeZero = (xuesha == 0 and haoqi == 0)

                if allShopZero or allChallengeZero then
                    -- 计算基础属性 = 初始 + 等级成长
                    local level = p.level or 1
                    local baseMaxHp  = 100 + (level - 1) * 15
                    local baseAtk    = 15  + (level - 1) * 3
                    local baseDef    = 5   + (level - 1) * 2
                    local baseRegen  = 1.0 + (level - 1) * 0.2

                    -- 累计境界突破奖励（遍历到当前境界之前的所有境界）
                    local realmHp, realmAtk, realmDef, realmRegen = 0, 0, 0, 0
                    local currentRealm = p.realm or "mortal"
                    for _, rid in ipairs(GameConfig.REALM_LIST) do
                        if rid == currentRealm then break end
                        local rd = GameConfig.REALMS[rid]
                        if rd and rd.rewards then
                            realmHp    = realmHp    + (rd.rewards.maxHp   or 0)
                            realmAtk   = realmAtk   + (rd.rewards.atk     or 0)
                            realmDef   = realmDef   + (rd.rewards.def     or 0)
                            realmRegen = realmRegen + (rd.rewards.hpRegen or 0)
                        end
                    end

                    local expectedMaxHp = baseMaxHp + realmHp
                    local expectedAtk   = baseAtk   + realmAtk
                    local expectedDef   = baseDef   + realmDef
                    local expectedRegen = baseRegen + realmRegen

                    local actualMaxHp = p.maxHp or expectedMaxHp
                    local actualAtk   = p.atk   or expectedAtk
                    local actualDef   = p.def   or expectedDef
                    local actualRegen = p.hpRegen or expectedRegen
                    local actualKillHeal = p.pillKillHeal or 0

                    -- 只要有任一属性溢出，就执行反推
                    local hasExcess = (actualMaxHp > expectedMaxHp)
                        or (actualAtk > expectedAtk)
                        or (actualDef > expectedDef)

                    if hasExcess then
                        local fixed = false

                        -- ── 挑战丹药反推（仅当 allChallengeZero 且有溢出时）──
                        if allChallengeZero then
                            -- 血煞丹反推：pillKillHeal 唯一来源
                            local xueshaPKH = findBonus(xueshaCfg, "pillKillHeal")
                            local calcXuesha = math.max(0, math.min(
                                math.floor(actualKillHeal / xueshaPKH + 0.5), xueshaCfg.maxUse))
                            -- 浩气丹反推：hpRegen 溢出
                            local haoqiRegen = findBonus(haoqiCfg, "hpRegen")
                            local regenDiff = actualRegen - expectedRegen
                            local calcHaoqi = math.max(0, math.min(
                                math.floor(regenDiff / haoqiRegen + 0.5), haoqiCfg.maxUse))

                            if calcXuesha > 0 or calcHaoqi > 0 then
                                ChallengeSystem.xueshaDanCount = calcXuesha
                                ChallengeSystem.haoqiDanCount = calcHaoqi
                                fixed = true
                                print("[SaveSystem][B3-Fix] Challenge pill counts restored:"
                                    .. " xuesha=" .. calcXuesha
                                    .. " haoqi=" .. calcHaoqi)
                            end
                        end

                        -- ── 商店丹药反推（仅当 allShopZero 且有溢出时）──
                        if allShopZero then
                            -- 已知挑战丹药贡献（用已恢复或已有的计数）
                            local knownXuesha = ChallengeSystem.xueshaDanCount or 0
                            local knownHaoqi  = ChallengeSystem.haoqiDanCount or 0

                            -- 金刚丹反推（唯一 def 丹药来源）
                            local defDiff = actualDef - expectedDef
                            local calcDiamond = math.max(0, math.min(
                                math.floor(defDiff / shopPillCfg.diamond.defBonus + 0.5), shopPillCfg.diamond.maxBuy))

                            -- 灵蛇丹反推：先扣除血煞丹贡献的 atk
                            local xueshaAtk = findBonus(xueshaCfg, "atk")
                            local atkFromXuesha = knownXuesha * xueshaAtk
                            local atkDiff = actualAtk - expectedAtk - atkFromXuesha
                            local calcSnake = math.max(0, math.min(
                                math.floor(atkDiff / shopPillCfg.snake.atkBonus + 0.5), shopPillCfg.snake.maxBuy))

                            -- 虎骨丹反推：先扣除浩气丹贡献的 maxHp
                            local haoqiHp = findBonus(haoqiCfg, "maxHp")
                            local hpFromHaoqi = knownHaoqi * haoqiHp
                            local hpDiff = actualMaxHp - expectedMaxHp - hpFromHaoqi
                            local calcTiger = math.max(0, math.min(
                                math.floor(hpDiff / shopPillCfg.tiger.hpBonus + 0.5), shopPillCfg.tiger.maxBuy))

                            if calcTiger > 0 or calcSnake > 0 or calcDiamond > 0 then
                                AlchemyUI.SetTigerPillCount(calcTiger)
                                AlchemyUI.SetSnakePillCount(calcSnake)
                                AlchemyUI.SetDiamondPillCount(calcDiamond)
                                fixed = true
                                print("[SaveSystem][B3-Fix] Shop pill counts restored:"
                                    .. " tiger=" .. calcTiger
                                    .. " snake=" .. calcSnake
                                    .. " diamond=" .. calcDiamond)
                            end
                        end

                        if fixed then
                            print("[SaveSystem][B3-Fix] Attribute baseline:"
                                .. " expectedHp=" .. expectedMaxHp
                                .. " actualHp=" .. actualMaxHp
                                .. " expectedAtk=" .. expectedAtk
                                .. " actualAtk=" .. actualAtk
                                .. " expectedDef=" .. expectedDef
                                .. " actualDef=" .. actualDef)
                        end
                    end
                end
            end
        end

        if saveData.sealDemon then
            local SealDemonSystem = require("systems.SealDemonSystem")
            SealDemonSystem.Deserialize(saveData.sealDemon, saveData.player and saveData.player.pillPhysique or 0)
        end

        if saveData.artifact then
            local ArtifactSystem = require("systems.ArtifactSystem")
            ArtifactSystem.Deserialize(saveData.artifact)
        end

        if saveData.fortuneFruits then
            local FortuneFruitSystem = require("systems.FortuneFruitSystem")
            FortuneFruitSystem.Deserialize(saveData.fortuneFruits)
        end

        if saveData.seaPillar then
            local SeaPillarSystem = require("systems.SeaPillarSystem")
            SeaPillarSystem.Deserialize(saveData.seaPillar)
        end

        if saveData.trialTower then
            local TrialTowerSystem = require("systems.TrialTowerSystem")
            TrialTowerSystem.Deserialize(saveData.trialTower)
        end

        -- 恢复BOSS击杀冷却（从相对剩余时间转换回绝对killTime）
        GameState.bossKillTimes = {}
        if saveData.bossKillTimes then
            for typeId, value in pairs(saveData.bossKillTimes) do
                -- 兼容旧格式（纯数字）和新格式（{remaining, respawnTime}）
                local remaining, respawnTime
                if type(value) == "table" then
                    remaining = value.remaining or 0
                    respawnTime = value.respawnTime or 180
                else
                    remaining = value  -- 旧格式：直接是数字
                    respawnTime = 180
                end
                if remaining > 0 then
                    -- 安全校验：remaining 不应超过 respawnTime（异常数据保护）
                    if remaining > respawnTime then
                        print("[SaveSystem] WARNING: Boss " .. typeId
                            .. " remaining=" .. string.format("%.0f", remaining)
                            .. " > respawnTime=" .. respawnTime .. ", clamping to respawnTime")
                        remaining = respawnTime
                    end
                    -- 安全校验：gameTime 应为 0（加载时尚未开始计时）
                    if GameState.gameTime ~= 0 then
                        print("[SaveSystem] WARNING: gameTime=" .. string.format("%.1f", GameState.gameTime)
                            .. " at boss cooldown restore, forcing to 0 for correct calculation")
                        GameState.gameTime = 0
                    end
                    -- 将剩余时间转为 killTime = gameTime - (respawnTime - remaining)
                    -- 即 killTime = gameTime - elapsed，使得 elapsed + remaining = respawnTime
                    GameState.bossKillTimes[typeId] = {
                        killTime = GameState.gameTime - (respawnTime - remaining),
                        respawnTime = respawnTime,
                    }
                    print("[SaveSystem] Boss cooldown restored: " .. typeId
                        .. " (" .. string.format("%.0f", remaining) .. "s remaining)")
                end
            end
        end

        -- 恢复BOSS累计击杀数（含历史迁移）
        if saveData._bossKillsMigrated then
            GameState.bossKills = saveData.bossKills or 0
        else
            -- 首次迁移：从 TitleSystem.killStats 统计历史 BOSS/王者击杀数
            local MonsterData = require("config.MonsterData")
            local TitleSystem = require("systems.TitleSystem")
            local histBossKills = 0
            for typeId, count in pairs(TitleSystem.killStats or {}) do
                local mType = MonsterData.Types[typeId]
                if mType and GameConfig.BOSS_CATEGORIES[mType.category] then
                    histBossKills = histBossKills + count
                end
            end
            GameState.bossKills = histBossKills
            print("[SaveSystem] Migrated historical BOSS kills: " .. histBossKills)
        end
    end)

    if not ok then
        print("[SaveSystem] Deserialization CRASHED: " .. tostring(err))
        SaveSystem.loaded = false
        if callback then callback(false, "存档解析失败: " .. tostring(err)) end
        return
    end

    -- 完整性校验
    local valid, errors = SaveSystem.ValidateLoadedState(cloudLevel)
    if not valid then
        local errMsg = table.concat(errors, "; ")
        print("[SaveSystem] Validation failed: " .. errMsg)
        SaveSystem.loaded = false
        if callback then callback(false, "存档校验失败: " .. errMsg) end
        return
    end

    -- 全部通过
    SaveSystem.loaded = true
    SaveSystem.activeSlot = slot

    -- 缓存云端等级（供本地安全阀使用）
    local player = GameState.player
    if player then
        SaveSystem._lastKnownCloudLevel = player.level
    end

    -- 从已有 realm+level 反算排行榜分数（不修改存档结构）
    do
        local pData = saveData.player or {}
        local rCfg = GameConfig.REALMS[pData.realm or "mortal"]
        local rOrder = rCfg and rCfg.order or 0
        GameState.lastRankScore = rOrder * 1000 + (pData.level or 1)
    end

    -- [诊断] 属性分解日志 —— 排查宠物攻击力异常（BUG#3700）
    do
        local p = GameState.player
        local pet = GameState.pet
        if p then
            local totalAtk = p:GetTotalAtk()
            print("[DIAG] ======== 属性诊断 ========")
            print("[DIAG] player.level=" .. p.level .. " realm=" .. tostring(p.realm))
            print("[DIAG] player.atk(base)=" .. p.atk)
            print("[DIAG] player.equipAtk=" .. (p.equipAtk or 0))
            print("[DIAG] player.collectionAtk=" .. (p.collectionAtk or 0))
            print("[DIAG] player.titleAtk=" .. (p.titleAtk or 0))
            print("[DIAG] player.titleAtkBonus=" .. (p.titleAtkBonus or 0))
            print("[DIAG] player.GetTotalAtk()=" .. totalAtk)

            -- 装备逐件atk分解
            local InventorySystem = require("systems.InventorySystem")
            local mgr = InventorySystem.GetManager()
            if mgr then
                local equipped = mgr:GetAllEquipment()
                local equipAtkSum = 0
                for slotId, item in pairs(equipped) do
                    local mainAtk = (item.mainStat and item.mainStat.atk) or 0
                    local subAtk = 0
                    if item.subStats then
                        for _, sub in ipairs(item.subStats) do
                            if sub.stat == "atk" then subAtk = subAtk + (sub.value or 0) end
                        end
                    end
                    local forgeAtk = (item.forgeStat and item.forgeStat.stat == "atk") and item.forgeStat.value or 0
                    local spiritAtk = (item.spiritStat and item.spiritStat.stat == "atk") and item.spiritStat.value or 0
                    local itemTotal = mainAtk + subAtk + forgeAtk + spiritAtk
                    equipAtkSum = equipAtkSum + itemTotal
                    if itemTotal > 0 then
                        print("[DIAG] equip[" .. slotId .. "] " .. (item.name or "?")
                            .. " q=" .. tostring(item.quality) .. " t=" .. tostring(item.tier)
                            .. " main=" .. mainAtk .. " sub=" .. subAtk
                            .. " forge=" .. forgeAtk .. " spirit=" .. spiritAtk
                            .. " sum=" .. itemTotal)
                    end
                end
                print("[DIAG] equipAtk recalc sum=" .. equipAtkSum .. " vs player.equipAtk=" .. (p.equipAtk or 0))
            end

            -- 宠物属性分解
            if pet then
                local syncRate = pet:GetSyncRate()
                local tierData = pet:GetTierData()
                local bd = pet:GetStatBreakdown()
                print("[DIAG] pet.level=" .. pet.level .. " tier=" .. pet.tier
                    .. " tierSyncRate=" .. tierData.syncRate
                    .. " totalSyncRate=" .. string.format("%.4f", syncRate))
                print("[DIAG] pet.atk=" .. pet.atk)
                if bd and bd.atk then
                    print("[DIAG] pet.atk breakdown: base=" .. bd.atk.base
                        .. " growth=" .. bd.atk.growth
                        .. " sync=" .. bd.atk.sync
                        .. " skillPct=" .. (bd.atk.skillPct or 0)
                        .. " total=" .. bd.atk.total)
                end
                -- 宠物技能详情（排查重复技能BUG#3700）
                local skillIds = {}
                for i = 1, (pet.GetSkillSlotCount and pet:GetSkillSlotCount() or 10) do
                    local sk = pet.skills[i]
                    if sk then
                        print("[DIAG] pet.skill[" .. i .. "] id=" .. sk.id .. " tier=" .. sk.tier)
                        skillIds[#skillIds + 1] = sk.id
                    end
                end
                local dupCheck = {}
                for _, sid in ipairs(skillIds) do
                    if dupCheck[sid] then
                        print("[DIAG] ⚠️ WARNING: 宠物技能重复! id=" .. sid .. " 出现多次！这是BUG#3700的根因！")
                    end
                    dupCheck[sid] = true
                end
                local skillBonuses = pet:GetSkillBonuses()
                print("[DIAG] pet.skillPct.atk=" .. (skillBonuses.atk or 0) .. " maxHp=" .. (skillBonuses.maxHp or 0) .. " def=" .. (skillBonuses.def or 0))

                -- 异常检测
                if pet.atk > 1500 then
                    print("[DIAG] ⚠️ WARNING: pet.atk=" .. pet.atk .. " 异常偏高！playerTotalAtk=" .. totalAtk .. " syncRate=" .. string.format("%.4f", syncRate))
                end
            end

            -- player.atk 合理性校验
            local expectedBaseAtk = GameConfig.PLAYER_INITIAL.atk + (p.level - 1) * GameConfig.LEVEL_GROWTH.atk
            print("[DIAG] player.atk expected(lv+init)=" .. expectedBaseAtk .. " actual=" .. p.atk .. " diff=" .. (p.atk - expectedBaseAtk))
            if p.atk > expectedBaseAtk + 1000 then
                print("[DIAG] ⚠️ WARNING: player.atk=" .. p.atk .. " 远超等级成长值" .. expectedBaseAtk .. "！差值含境界+丹药，但差" .. (p.atk - expectedBaseAtk) .. "仍需确认")
            end
            print("[DIAG] =============================")
        end
    end

    EventBus.Emit("game_loaded")

    -- 登录备份：加载成功后将这份已验证的数据写入独立 key
    -- 这是独立于 save_prev（存档管线产生）的第二道防线
    -- v11: 单键写入 login_{slot}，包含完整数据（equipment + backpack 嵌入）
    -- 🔴 防御改进：降级保护 — 先读取已有备份，防止恢复后的最小数据覆盖完整备份
    local loginKey = SaveSystem.GetKey("login", slot)
    local legacyKeys = SaveSystem.GetLegacyKeys(slot)
    local currentLevel = saveData.player and saveData.player.level or 0
    local hasInventory = saveData.inventory and (saveData.inventory.equipment or saveData.inventory.backpack)

    -- v11: 构建单键备份数据（equipment + backpack 嵌入顶层）
    local backupData = {}
    for k, v in pairs(saveData) do
        if k ~= "inventory" then backupData[k] = v end
    end
    local bkpInv = saveData.inventory or {}
    backupData.equipment = bkpInv.equipment or {}
    backupData.backpack = bkpInv.backpack or {}

    -- 🔴 防御改进 3：恢复标记保护 — 元数据重建的最小存档绝不覆盖登录备份
    if saveData._recoveredFromMeta then
        print("[SaveSystem] Login backup SKIPPED: data is recovered from metadata rebuild, preserving existing backup")
        saveData._recoveredFromMeta = nil
        goto skip_login_backup
    end

    CloudStorage.BatchGet()
        :Key(loginKey)
        :Fetch({
            ok = function(existingValues)
                local existing = existingValues[loginKey]
                local existingLevel = 0
                local existingHasInventory = false
                if existing and type(existing) == "table" and existing.player then
                    existingLevel = existing.player.level or 0
                    existingHasInventory = existing.equipment or existing.backpack
                        or (existing.inventory and (existing.inventory.equipment or existing.inventory.backpack))
                end

                -- 降级保护：如果已有备份等级更高且有装备数据，而当前数据没有装备
                if existingLevel > currentLevel + 5 and existingHasInventory and not hasInventory then
                    print("[SaveSystem] Login backup PRESERVED: existing Lv." .. existingLevel
                        .. " > current Lv." .. currentLevel .. " (recovery data, skipping overwrite)")
                    return
                end

                -- v11 单键写入 + 清理旧登录备份 key
                CloudStorage.BatchSet()
                    :Set(loginKey, backupData)
                    :Delete(legacyKeys.login)
                    :Delete(legacyKeys.loginBag1)
                    :Delete(legacyKeys.loginBag2)
                    :Save("登录备份", {
                        ok = function()
                            print("[SaveSystem] Login backup saved for slot " .. slot
                                .. " (Lv." .. currentLevel .. ") [v11]")
                        end,
                        error = function(code, reason)
                            print("[SaveSystem] Login backup failed: " .. tostring(reason))
                        end,
                    })
            end,
            error = function(code, reason)
                print("[SaveSystem] Login backup read failed, writing anyway: " .. tostring(reason))
                CloudStorage.BatchSet()
                    :Set(loginKey, backupData)
                    :Delete(legacyKeys.login)
                    :Delete(legacyKeys.loginBag1)
                    :Delete(legacyKeys.loginBag2)
                    :Save("登录备份(降级)", {
                        ok = function()
                            print("[SaveSystem] Login backup saved (fallback) for slot " .. slot .. " [v11]")
                        end,
                        error = function(code2, reason2)
                            print("[SaveSystem] Login backup failed: " .. tostring(reason2))
                        end,
                    })
            end,
        })

    ::skip_login_backup::

    local msg = "读档成功"
    if recoverySource then
        msg = "已从" .. recoverySource .. "恢复（可能丢失部分进度）"
        print("[SaveSystem] Slot " .. slot .. " RECOVERED from " .. recoverySource
            .. "! Version: " .. tostring(saveData.version))
    else
        print("[SaveSystem] Slot " .. slot .. " loaded! Version: " .. tostring(saveData.version))
    end
    if callback then callback(true, msg) end
end

--- 尝试从备份源恢复丢失的存档
--- 优先级：save_login_backup_X（登录备份）→ save_prev_X（定期备份）→ save_backup_X（删除备份）→ save_data/slots_index 取等级高者
---@param slot number 槽位号
---@param callback function(success: boolean, message: string)
function SaveSystem.TryRecoverSave(slot, callback)
    print("[SaveSystem] Attempting recovery for slot " .. slot .. "...")

    -- v11 新格式备份 key
    local newLoginKey = SaveSystem.GetKey("login", slot)
    local newPrevKey = SaveSystem.GetKey("prev", slot)
    local newDeletedKey = SaveSystem.GetKey("deleted", slot)
    -- v10 旧格式备份 key（兼容窗口）
    local legacy = SaveSystem.GetLegacyKeys(slot)

    CloudStorage.BatchGet()
        :Key(newLoginKey)         -- v11 登录备份
        :Key(newPrevKey)          -- v11 定期备份
        :Key(newDeletedKey)       -- v11 删除备份
        :Key(legacy.login)        -- v10 登录备份
        :Key(legacy.loginBag1)    -- v10 登录备份 - bag1
        :Key(legacy.loginBag2)    -- v10 登录备份 - bag2
        :Key(legacy.prev)         -- v10 定期备份
        :Key(legacy.prevBag1)     -- v10 定期备份 - bag1
        :Key(legacy.prevBag2)     -- v10 定期备份 - bag2
        :Key(legacy.backup)       -- v10 删除备份
        :Key(legacy.bakBag1)      -- v10 删除备份 - bag1
        :Key(legacy.bakBag2)      -- v10 删除备份 - bag2
        :Key("slots_index")       -- 元数据兜底
        :Fetch({
            ok = function(values)
                --- 从备份数据重建 inventory
                --- v11 格式：backpack 已嵌入 coreData，直接提取
                --- v10 格式：从 bag1/bag2 键合并
                local function rebuildInventory(data, bag1KeyName, bag2KeyName)
                    if not data then return data end
                    -- v11 检测：backpack 已嵌入在 data 中
                    if data.backpack and type(data.backpack) == "table" then
                        data.inventory = {
                            equipment = data.equipment or {},
                            backpack = data.backpack,
                        }
                        data.equipment = nil
                        data.backpack = nil
                        return data
                    end
                    -- v10 fallback：从外部 bag key 合并
                    local b1 = values[bag1KeyName]
                    local b2 = values[bag2KeyName]
                    local backpack = {}
                    -- 兼容旧版删除备份：bag 键可能被包装为 { data = ..., deletedAt = ... }
                    if b1 and type(b1) == "table" then
                        local realB1 = (b1.data and type(b1.data) == "table" and b1.deletedAt) and b1.data or b1
                        for k, v in pairs(realB1) do backpack[k] = v end
                    end
                    if b2 and type(b2) == "table" then
                        local realB2 = (b2.data and type(b2.data) == "table" and b2.deletedAt) and b2.data or b2
                        for k, v in pairs(realB2) do backpack[k] = v end
                    end
                    data.inventory = {
                        equipment = data.equipment or {},
                        backpack = backpack,
                    }
                    data.equipment = nil
                    return data
                end

                -- 🔴 改进：收集所有候选恢复源，取等级最高者（防止降级循环）
                local candidates = {}

                -- 候选: v11 login_{slot}（新格式登录备份）
                if values[newLoginKey] and type(values[newLoginKey]) == "table" then
                    local lb = rebuildInventory(values[newLoginKey], nil, nil)
                    if lb and lb.player then
                        local lv = lb.player.level or 1
                        table.insert(candidates, { data = lb, source = "v11登录备份", level = lv, key = newLoginKey })
                        print("[SaveSystem] Recovery candidate: " .. newLoginKey .. " Lv." .. lv)
                    end
                end

                -- 候选: v10 save_login_backup_X（旧格式登录备份）
                if values[legacy.login] and type(values[legacy.login]) == "table" then
                    local lb = rebuildInventory(values[legacy.login], legacy.loginBag1, legacy.loginBag2)
                    if lb and lb.player then
                        local lv = lb.player.level or 1
                        table.insert(candidates, { data = lb, source = "v10登录备份", level = lv, key = legacy.login })
                        print("[SaveSystem] Recovery candidate: " .. legacy.login .. " Lv." .. lv)
                    end
                end

                -- 候选: v11 prev_{slot}（新格式定期备份）
                if values[newPrevKey] and type(values[newPrevKey]) == "table" then
                    local prev = rebuildInventory(values[newPrevKey], nil, nil)
                    if prev and prev.player then
                        local lv = prev.player.level or 1
                        table.insert(candidates, { data = prev, source = "v11定期备份", level = lv, key = newPrevKey })
                        print("[SaveSystem] Recovery candidate: " .. newPrevKey .. " Lv." .. lv)
                    end
                end

                -- 候选: v10 save_prev_X（旧格式定期备份）
                if values[legacy.prev] and type(values[legacy.prev]) == "table" then
                    local prev = rebuildInventory(values[legacy.prev], legacy.prevBag1, legacy.prevBag2)
                    if prev and prev.player then
                        local lv = prev.player.level or 1
                        table.insert(candidates, { data = prev, source = "v10定期备份", level = lv, key = legacy.prev })
                        print("[SaveSystem] Recovery candidate: " .. legacy.prev .. " Lv." .. lv)
                    end
                end

                -- 候选: v11 deleted_{slot}（新格式删除备份）
                if values[newDeletedKey] and type(values[newDeletedKey]) == "table" then
                    local backup = values[newDeletedKey]
                    local bkData = (backup.data and type(backup.data) == "table") and backup.data or backup
                    if bkData.player then
                        rebuildInventory(bkData, nil, nil)
                        local lv = bkData.player.level or 1
                        table.insert(candidates, { data = bkData, source = "v11删除备份", level = lv, key = newDeletedKey })
                        print("[SaveSystem] Recovery candidate: " .. newDeletedKey .. " Lv." .. lv)
                    end
                end

                -- 候选: v10 save_backup_X（旧格式删除备份）
                if values[legacy.backup] and type(values[legacy.backup]) == "table" then
                    local backup = values[legacy.backup]
                    if backup.data and type(backup.data) == "table" and backup.data.player then
                        rebuildInventory(backup.data, legacy.bakBag1, legacy.bakBag2)
                        local lv = backup.data.player.level or 1
                        table.insert(candidates, { data = backup.data, source = "v10删除备份", level = lv, key = legacy.backup })
                        print("[SaveSystem] Recovery candidate: " .. legacy.backup .. " Lv." .. lv)
                    end
                end

                -- 从所有候选中选出等级最高的
                local recoveredData = nil
                local recoverySource = nil
                local bestLevel = 0
                for _, c in ipairs(candidates) do
                    if c.level > bestLevel then
                        bestLevel = c.level
                        recoveredData = c.data
                        recoverySource = c.source
                    end
                end
                if recoveredData then
                    print("[SaveSystem] Best recovery source: " .. recoverySource .. " (Lv." .. bestLevel .. ")")
                end

                -- 最后手段：从 slots_index 元数据重建最小存档
                if not recoveredData then
                    local rebuildData = nil
                    local rebuildLevel = 0
                    local slotsIndex = values["slots_index"]
                    if slotsIndex and slotsIndex.slots and slotsIndex.slots[slot] then
                        local meta = slotsIndex.slots[slot]
                        rebuildLevel = meta.level or 1
                        local rebuildRealm = meta.realm or "mortal"
                        local rebuildChapter = meta.chapter or 1

                        local baseHp = 100 + (rebuildLevel - 1) * 15
                        local baseAtk = 15 + (rebuildLevel - 1) * 3
                        local baseDef = 5 + (rebuildLevel - 1) * 2

                        -- 计算与等级匹配的 hpRegen（基础 1.0 + 每级 0.2）
                        local baseHpRegen = 1.0 + (rebuildLevel - 1) * 0.2

                        -- 计算累计境界突破属性奖励
                        local realmBonusHp, realmBonusAtk, realmBonusDef, realmBonusRegen = 0, 0, 0, 0
                        for _, rid in ipairs(GameConfig.REALM_LIST) do
                            if rid == rebuildRealm then break end
                            local rd = GameConfig.REALMS[rid]
                            if rd and rd.rewards then
                                realmBonusHp = realmBonusHp + (rd.rewards.maxHp or 0)
                                realmBonusAtk = realmBonusAtk + (rd.rewards.atk or 0)
                                realmBonusDef = realmBonusDef + (rd.rewards.def or 0)
                                realmBonusRegen = realmBonusRegen + (rd.rewards.hpRegen or 0)
                            end
                        end

                        -- 设置与等级匹配的最低经验值（否则经验条显示负数/0%）
                        local rebuildExp = GameConfig.EXP_TABLE[rebuildLevel] or 0

                        rebuildData = {
                            version = SaveSystem.CURRENT_SAVE_VERSION,
                            timestamp = os.time(),
                            player = {
                                level = rebuildLevel,
                                exp = rebuildExp,
                                hp = baseHp + realmBonusHp,
                                maxHp = baseHp + realmBonusHp,
                                atk = baseAtk + realmBonusAtk,
                                def = baseDef + realmBonusDef,
                                hpRegen = baseHpRegen + realmBonusRegen,
                                gold = 1000,
                                lingYun = 0,
                                realm = rebuildRealm,
                                chapter = rebuildChapter,
                                -- B4-S4.1: 补全缺失的 player 字段（零值安全默认）
                                pillKillHeal = 0,
                                pillConstitution = 0,
                                fruitFortune = 0,
                                daoTreeWisdom = 0,
                                daoTreeWisdomPity = 0,
                                pillPhysique = 0,
                                x = 0,
                                y = 0,
                                -- B4-S4.1 补丁：海神柱属性加成（与 SerializePlayer 对齐）
                                seaPillarDef = 0,
                                seaPillarAtk = 0,
                                seaPillarMaxHp = 0,
                                seaPillarHpRegen = 0,
                            },
                            inventory = {},
                            skills = {},
                            collection = {},
                            pet = {},
                            quests = {},
                            shop = {},
                            titles = {},
                            -- B4-S4.1: 补全缺失的子系统空结构
                            challenges = {},
                            sealDemon = { quests = {} },
                            bulletin = {},
                            artifact = {},
                            fortuneFruits = { collected = {} },
                            trialTower = {},
                            bossKillTimes = {},
                            -- B4-S4.1 补丁：与 SerializeAll 对齐的顶层字段
                            code_version = GameConfig.CODE_VERSION,
                            bossKills = 0,
                            _bossKillsMigrated = true,
                            seaPillar = {},
                        }
                    end

                    if rebuildData then
                        recoveredData = rebuildData
                        recoveredData._recoveredFromMeta = true  -- 标记为元数据重建的最小存档
                        recoverySource = "元数据重建(仅保留等级境界)"
                        print("[SaveSystem] Last resort: rebuilding from slots_index meta — Lv."
                            .. rebuildLevel)
                    end
                end

                if not recoveredData then
                    print("[SaveSystem] No recovery source found for slot " .. slot)
                    SaveSystem.loaded = false
                    if callback then callback(false, "存档数据丢失，未找到可恢复的备份") end
                    return
                end

                -- 将恢复的数据写回（v11 单 key 格式），同时同步 slots_index
                -- ⚠️ 必须同步 slots_index！否则安全阀会因等级落差永久阻止存档
                local recSaveKey = SaveSystem.GetKey("save", slot)
                local recoveredPlayer = recoveredData.player or {}
                local recoveredLevel = recoveredPlayer.level or 1
                local recoveredRealm = recoveredPlayer.realm or "mortal"
                local realmCfg = GameConfig.REALMS[recoveredRealm]
                local realmName = realmCfg and realmCfg.name or "凡人"

                -- v11 单 key 格式：equipment + backpack 提升到顶层
                local recInv = recoveredData.inventory or {}
                local recCoreData = {}
                for k, v in pairs(recoveredData) do
                    if k ~= "inventory" then recCoreData[k] = v end
                end
                recCoreData.equipment = recInv.equipment or {}
                recCoreData.backpack = recInv.backpack or {}

                -- 读取当前 slots_index 并更新对应槽位
                CloudStorage.BatchGet()
                    :Key("slots_index")
                    :Fetch({
                        ok = function(idxValues)
                            local updatedIndex = idxValues.slots_index or { version = 1, slots = {} }
                            updatedIndex.slots = updatedIndex.slots or {}
                            local oldName = SaveSystem.DEFAULT_CHARACTER_NAME
                            if updatedIndex.slots[slot] then
                                oldName = updatedIndex.slots[slot].name or oldName
                            end
                            -- 用恢复数据的实际等级覆写 slots_index
                            updatedIndex.slots[slot] = {
                                name = oldName,
                                level = recoveredLevel,
                                realm = recoveredRealm,
                                realmName = realmName,
                                chapter = recoveredPlayer.chapter or 1,
                                lastSave = os.time(),
                                saveVersion = recoveredData.version or 1,
                            }
                            local batch = CloudStorage.BatchSet()
                                :Set(recSaveKey, recCoreData)
                                :Set("slots_index", updatedIndex)
                            -- 清理旧格式 key（如存在）
                            batch:Delete(legacy.save)
                            batch:Delete(legacy.bag1)
                            batch:Delete(legacy.bag2)
                            batch:Save("恢复存档+同步索引", {
                                    ok = function()
                                        print("[SaveSystem] Recovery: data + slots_index synced for slot " .. slot .. " [single-key]")
                                    end,
                                    error = function(code, reason)
                                        print("[SaveSystem] Recovery write-back failed: " .. tostring(reason))
                                    end,
                                })
                        end,
                        error = function(code, reason)
                            -- 即使读索引失败，也要写回存档数据
                            print("[SaveSystem] Recovery: slots_index read failed, writing data only: " .. tostring(reason))
                            local batch = CloudStorage.BatchSet()
                                :Set(recSaveKey, recCoreData)
                            batch:Delete(legacy.save)
                            batch:Delete(legacy.bag1)
                            batch:Delete(legacy.bag2)
                            batch:Save("恢复存档", {
                                    ok = function()
                                        print("[SaveSystem] Recovery data written back to " .. recSaveKey .. " [single-key]")
                                    end,
                                    error = function(code2, reason2)
                                        print("[SaveSystem] Recovery write-back failed: " .. tostring(reason2))
                                    end,
                                })
                        end,
                    })

                -- 立即用恢复的数据进行反序列化（不等写回完成）
                SaveSystem.ProcessLoadedData(slot, recoveredData, recoverySource, callback)
            end,
            error = function(code, reason)
                print("[SaveSystem] Recovery query failed: " .. tostring(reason))
                SaveSystem.loaded = false
                if callback then callback(false, "存档数据为空，备份查询失败: " .. tostring(reason)) end
            end,
        })
end

--- 加载指定槽位的存档
---@param slot number 槽位号 (1 或 2)
---@param callback function(success: boolean, message: string)
function SaveSystem.Load(slot, callback)
    -- 网络模式：通过 C2S_LoadGame 远程事件路由到服务端
    if CloudStorage.IsNetworkMode() then
        return SaveSystemNet.Load(slot, callback)
    end

    print("[SaveSystem] Loading slot " .. slot .. "...")

    -- v11 新 key + 旧 key（兼容窗口）
    local newKey = SaveSystem.GetKey("save", slot)
    local legacy = SaveSystem.GetLegacyKeys(slot)

    CloudStorage.BatchGet()
        :Key(newKey)
        :Key(legacy.save)
        :Key(legacy.bag1)
        :Key(legacy.bag2)
        :Fetch({
            ok = function(values)
                local newData = values[newKey]
                local oldData = values[legacy.save]
                local bag1 = values[legacy.bag1]
                local bag2 = values[legacy.bag2]

                local saveData = nil

                -- 优先使用 v11 新格式
                if newData and type(newData) == "table" then
                    -- v11 格式：backpack 已嵌入 coreData
                    saveData = newData
                    saveData.inventory = {
                        equipment = saveData.equipment or {},
                        backpack = saveData.backpack or {},
                    }
                    saveData.equipment = nil
                    saveData.backpack = nil
                    print("[SaveSystem] Loaded from v11 key: " .. newKey)

                elseif oldData and type(oldData) == "table" then
                    -- v10 旧格式 fallback：三键合并
                    saveData = oldData
                    local backpack = {}
                    if bag1 and type(bag1) == "table" then
                        for k, v in pairs(bag1) do backpack[k] = v end
                    end
                    if bag2 and type(bag2) == "table" then
                        for k, v in pairs(bag2) do backpack[k] = v end
                    end
                    saveData.inventory = {
                        equipment = saveData.equipment or {},
                        backpack = backpack,
                    }
                    saveData.equipment = nil
                    print("[SaveSystem] Loaded from legacy 3-key format (fallback)")

                    -- 🔴 缓存旧格式原始数据，供 DoSave 首次迁移时写入 premigrate 快照
                    SaveSystem._rawOldData = SaveSystem._rawOldData or {}
                    SaveSystem._rawOldData[slot] = {
                        coreData = oldData,  -- 注意：此时 oldData.equipment 已被清除
                        bag1 = bag1 or {},
                        bag2 = bag2 or {},
                    }
                    -- 补回 equipment 到快照（因为上面 saveData.equipment = nil 会影响 oldData 引用）
                    if not SaveSystem._rawOldData[slot].coreData.equipment then
                        SaveSystem._rawOldData[slot].coreData.equipment = saveData.inventory.equipment
                    end
                else
                    -- 云端数据丢失：优先使用本地缓存
                    local cached = SaveSystem._lastSavedData and SaveSystem._lastSavedData[slot]
                    if cached and type(cached) == "table" then
                        print("[SaveSystem] Cloud data nil but LOCAL CACHE available for slot " .. slot
                            .. " (Lv." .. (cached.player and cached.player.level or "?") .. "), using cached data")
                        saveData = cached
                    else
                        print("[SaveSystem] Slot " .. slot .. " is empty, attempting recovery...")
                        SaveSystem.TryRecoverSave(slot, callback)
                        return
                    end
                end

                SaveSystem.ProcessLoadedData(slot, saveData, nil, callback)
            end,
            error = function(code, reason)
                print("[SaveSystem] Load failed: " .. tostring(reason))
                SaveSystem.loaded = false
                if callback then callback(false, reason) end
            end,
        })
end

-- ============================================================================
-- 创建新角色
-- ============================================================================

--- 在指定槽位创建新角色存档
---@param slot number 槽位号
---@param charName string 角色名
---@param slotsIndex table 当前的 slots_index
---@param callback function(success: boolean, message: string|nil)
function SaveSystem.CreateCharacter(slot, charName, slotsIndex, callback)
    -- 网络模式：通过 C2S_CreateChar 远程事件路由到服务端
    if CloudStorage.IsNetworkMode() then
        return SaveSystemNet.CreateCharacter(slot, charName, slotsIndex, callback)
    end

    print("[SaveSystem] Creating character '" .. charName .. "' in slot " .. slot)

    -- 构建初始存档数据
    local initialPlayer = {
        level = GameConfig.PLAYER_INITIAL.level,
        exp = GameConfig.PLAYER_INITIAL.exp,
        hp = GameConfig.PLAYER_INITIAL.hp,
        maxHp = GameConfig.PLAYER_INITIAL.maxHp,
        atk = GameConfig.PLAYER_INITIAL.atk,
        def = GameConfig.PLAYER_INITIAL.def,
        hpRegen = GameConfig.PLAYER_INITIAL.hpRegen,
        gold = GameConfig.PLAYER_INITIAL.gold,
        lingYun = GameConfig.PLAYER_INITIAL.lingYun,
        realm = GameConfig.PLAYER_INITIAL.realm,
    }

    -- v11 单 key 架构：equipment + backpack 嵌入顶层
    local coreData = {
        version = SaveSystem.CURRENT_SAVE_VERSION,
        timestamp = os.time(),
        player = initialPlayer,
        equipment = {},  -- 初始无装备
        backpack = {},   -- 初始背包为空
        skills = {},
        collection = {},
        pet = {},
        quests = {},
    }

    -- 更新索引
    local updatedIndex = slotsIndex or { version = 1, slots = {} }
    updatedIndex.slots = updatedIndex.slots or {}
    updatedIndex.slots[slot] = SaveSystem.BuildSlotSummary(slot, charName, initialPlayer)

    local saveKey = SaveSystem.GetKey("save", slot)

    CloudStorage.BatchSet()
        :Set(saveKey, coreData)
        :Set("slots_index", updatedIndex)
        :Save("创建角色", {
            ok = function()
                print("[SaveSystem] Character '" .. charName .. "' created in slot " .. slot .. " [single-key]")
                if callback then callback(true) end
            end,
            error = function(code, reason)
                print("[SaveSystem] Create character failed: " .. tostring(reason))
                if callback then callback(false, reason) end
            end,
        })
end

-- ============================================================================
-- 删除角色
-- ============================================================================

--- 删除指定槽位的角色
---@param slot number 槽位号
---@param slotsIndex table 当前的 slots_index
---@param callback function(success: boolean, message: string|nil)
function SaveSystem.DeleteCharacter(slot, slotsIndex, callback)
    -- 网络模式：通过 C2S_DeleteChar 远程事件路由到服务端
    if CloudStorage.IsNetworkMode() then
        return SaveSystemNet.DeleteCharacter(slot, slotsIndex, callback)
    end

    print("[SaveSystem] Deleting character in slot " .. slot)

    local newSaveKey = SaveSystem.GetKey("save", slot)
    local newDeletedKey = SaveSystem.GetKey("deleted", slot)
    local legacy = SaveSystem.GetLegacyKeys(slot)

    -- 读取 v11 + v10 存档数据做备份
    CloudStorage.BatchGet()
        :Key(newSaveKey)
        :Key(legacy.save)
        :Key(legacy.bag1)
        :Key(legacy.bag2)
        :Fetch({
            ok = function(values)
                local newData = values[newSaveKey]
                local oldData = values[legacy.save]
                local b1Data = values[legacy.bag1]
                local b2Data = values[legacy.bag2]

                -- 更新索引：移除该槽位
                local updatedIndex = slotsIndex or { version = 1, slots = {} }
                updatedIndex.slots = updatedIndex.slots or {}
                updatedIndex.slots[slot] = nil

                local rankScoreKey = "rank_score_" .. slot
                local rankInfoKey = "rank_info_" .. slot

                local batch = CloudStorage.BatchSet()
                    :Set("slots_index", updatedIndex)
                    :Delete(newSaveKey)
                    :Delete(rankScoreKey)
                    :Delete(rankInfoKey)
                -- 清理旧格式 key
                batch:Delete(legacy.save)
                batch:Delete(legacy.bag1)
                batch:Delete(legacy.bag2)

                -- 合并出完整的备份数据（v11 单 key 格式）
                local backupData = nil
                if newData and type(newData) == "table" then
                    -- v11 格式直接使用
                    backupData = newData
                elseif oldData and type(oldData) == "table" then
                    -- v10 格式：合并 bag
                    backupData = oldData
                    local backpack = {}
                    if b1Data and type(b1Data) == "table" then
                        for k, v in pairs(b1Data) do backpack[k] = v end
                    end
                    if b2Data and type(b2Data) == "table" then
                        for k, v in pairs(b2Data) do backpack[k] = v end
                    end
                    backupData.backpack = backpack
                end

                -- 如果有存档数据，备份到 deleted_{slot}（v11 单 key 格式）
                if backupData then
                    batch:Set(newDeletedKey, {
                        data = backupData,
                        deletedAt = os.time(),
                    })
                end

                batch:Save("删除角色", {
                    ok = function()
                        print("[SaveSystem] Character in slot " .. slot .. " deleted (backup saved) [single-key]")
                        if callback then callback(true) end
                    end,
                    error = function(code, reason)
                        print("[SaveSystem] Delete character failed: " .. tostring(reason))
                        if callback then callback(false, reason) end
                    end,
                })
            end,
            error = function(code, reason)
                print("[SaveSystem] Cannot read save for backup: " .. tostring(reason))
                if callback then callback(false, reason) end
            end,
        })
end

return SaveSystem
