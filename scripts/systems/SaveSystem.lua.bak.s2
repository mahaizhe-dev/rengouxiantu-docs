function SaveSystem.SerializeShop()
    local AlchemyUI = require("ui.AlchemyUI")
    return {
        tigerPillCount = AlchemyUI.GetTigerPillCount(),
        snakePillCount = AlchemyUI.GetSnakePillCount(),
        diamondPillCount = AlchemyUI.GetDiamondPillCount(),
        temperingPillEaten = AlchemyUI.GetTemperingPillEaten(),
    }
